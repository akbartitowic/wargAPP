<nav class="md:hidden bg-surface-container-lowest text-primary fixed bottom-0 w-full z-50 flex justify-around items-center px-4 py-2 rounded-t-xl shadow-[0_-4px_12px_rgba(0,0,0,0.05)] shadow-lg font-label-sm text-label-sm">

NODE_ENV=development
PORT=3000

# NIK/KK utuh di CMS & app warga saat development. Set true untuk memaksa masking di lokal.
# MASK_SENSITIVE_IDS=false

DATABASE_URL=postgresql://warga:warga_dev@localhost:5433/wargapp

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=30d
JWT_ADMIN_EXPIRES_IN=8h

UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=2097152

CORS_ORIGIN=http://localhost:5173,http://localhost:5174
PUBLIC_BASE_URL=http://localhost:3000
